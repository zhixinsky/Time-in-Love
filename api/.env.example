# 复制为 .env 后填写（勿提交 .env 到 Git）

NODE_ENV=development
PORT=3000
ADMIN_TOKEN=请设置一个强密码
ADMIN_JWT_SECRET=请设置JWT密钥

# 默认管理员（首次启动自动创建，请及时修改密码）
# 用户名 admin / 密码 admin123456

# 微信小程序
WX_APPID=wxb76bea40dcb2999b
WX_APP_SECRET=

# 微信云开发 / 云托管环境 ID
WX_CLOUD_ENV_ID=prod-d0gd8tvq9c6e19eb3

# —— 云托管控制台自动注入（服务绑定 MySQL / 云存储后会有） ——
# MYSQL_ADDRESS=10.x.x.x:3306
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=
# COS_BUCKET=7072-prod-xxx
# COS_REGION=ap-shanghai

# —— 本地开发可用手动命名（与上面对应） ——
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=love

# 背景音乐扫描目录（可选）
LOVE_MUSIC_COS_PREFIX=music/
LOVE_MUSIC_COVER_KEY=love-bg.png

# AI 星芽 / 小米 MiMo（OpenAI 兼容接口）
AI_PROVIDER=xiaomi
XIAOMI_API_KEY=
XIAOMI_AI_BASE_URL=https://api.mimo-v2.com/v1
XIAOMI_AI_MODEL=mimo-v2-flash
AI_TIMEOUT_MS=20000
